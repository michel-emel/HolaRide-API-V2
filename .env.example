# Copy this file to .env and fill in your real values.

# "development" or "production". In production, OTP_DEV_MODE is
# forcibly disabled even if you forget to set it below — see
# app/config.py for why that matters.
ENVIRONMENT=development

# This is the connection string `supabase start` printed you.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Any long random string — used to sign login tokens.
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-this-to-a-long-random-string

# When true, OTP codes are logged instead of being sent by real SMS.
# Keep this true until you pick an SMS provider.
OTP_DEV_MODE=true

# Comma-separated list of origins allowed to call this API from a
# browser (only matters for web clients, e.g. a Flutter web build).
# Mobile apps calling the API directly are never affected by this.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# PawaPay sandbox credentials. Get a token from your PawaPay sandbox
# dashboard (Developers > API tokens). NEVER paste a real token
# anywhere except this file — not in chat, not in code, not in git.
PAWAPAY_API_TOKEN=eyJraWQiOiIxIiwiYWxnIjoiRVMyNTYifQ.eyJ0dCI6IkFBVCIsInN1YiI6IjIzNTgyIiwibWF2IjoiMSIsImV4cCI6MjA5NzY2MjQwNSwiaWF0IjoxNzgyMDQzMjA1LCJwbSI6IkRBRixQQUYiLCJqdGkiOiJkNjA5MmIwNy1hYjdiLTQ0N2EtYWM1Yy04NjA3MzVhNmZkYWQifQ.yJ-YlJ-8GxTFWr-6-nqoutpPyAiclxHrbBzVtF2HabjAA6SS_uBykt1DnvG-sd8c8qSjCwMxYhGPq9y9wud5Wg
PAWAPAY_BASE_URL=https://api.sandbox.pawapay.io

# Twilio — only needed if SMS_PROVIDER=twilio. Get these from
# console.twilio.com. TWILIO_FROM_NUMBER is the number Twilio gave
# you on signup (trial accounts get one for free).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Termii — only needed if SMS_PROVIDER=termii (the default). Get
# these from your Termii dashboard. NEVER paste real values anywhere
# except this file.
TERMII_API_KEY=TLolKRjNXSiDUOynIRNeVsaPYkqkWbbHcdYnXqXFweKCzOUHHOxxAHOQscTCra
TERMII_SENDER_ID=HolaRide
TERMII_CHANNEL=dnd

# Which provider actually sends OTPs once OTP_DEV_MODE=false: "termii" or "twilio"
SMS_PROVIDER=termii


# Upstash Redis — only needed for rate limiting to actually work once
# deployed (e.g. on Vercel). Leave blank for local dev; rate limiting
# is simply skipped, not enforced incorrectly, when these are empty.
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# Supabase Storage — for vehicle photo uploads. Find both under your
# Supabase project's Settings > API. NOTE: this is a DIFFERENT
# credential than DATABASE_URL's password — this is the Storage API,
# not Postgres. NEVER paste real values anywhere except this file.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_VEHICLE_PHOTOS_BUCKET=vehicle-photos
